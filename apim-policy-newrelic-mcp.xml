<policies>
  <inbound>
    <base />

    <!-- ===================================================================
         Client Authentication: Entra ID JWT validation
         Developers authenticate with their AMN Entra credentials
         ==================================================================== -->
    <validate-azure-ad-token
      tenant-id="6232c2ec-fa42-4f27-92cd-787913fba489"
      header-name="Authorization"
      failed-validation-httpcode="401">
      <audiences>
        <!-- Accept tokens for APIM MCP access app registration -->
        <audience>{{newrelic-mcp-app-id}}</audience>
        <audience>api://{{newrelic-mcp-app-id}}</audience>
      </audiences>
    </validate-azure-ad-token>

    <!-- Extract user identity for audit logging -->
    <set-variable name="userOid" value="@{
      var authHeader = context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, string.Empty);
      if (!string.IsNullOrEmpty(authHeader) &amp;&amp; authHeader.StartsWith(&quot;Bearer &quot;)) {
        try {
          var jwt = authHeader.Substring(7).AsJwt();
          if (jwt != null) {
            var oid = jwt.Claims.GetValueOrDefault(&quot;oid&quot;, string.Empty);
            var upn = jwt.Claims.GetValueOrDefault(&quot;upn&quot;, string.Empty);
            return !string.IsNullOrEmpty(oid) ? oid : upn;
          }
        } catch { }
      }
      return &quot;anonymous&quot;;
    }" />

    <set-header name="x-apim-user-id" exists-action="override">
      <value>@((string)context.Variables["userOid"])</value>
    </set-header>

    <!-- Correlation ID for request tracing -->
    <set-variable name="correlationId"
                  value='@(context.Request.Headers.GetValueOrDefault("x-correlation-id", Guid.NewGuid().ToString()))' />

    <set-header name="x-correlation-id" exists-action="override">
      <value>@((string)context.Variables["correlationId"])</value>
    </set-header>

    <!-- ===================================================================
         Rate Limiting: Per-user throttling
         Prevent runaway queries to New Relic
         ==================================================================== -->
    <rate-limit-by-key
      calls="300"
      renewal-period="60"
      counter-key='@((string)context.Variables["userOid"])'
      remaining-calls-header-name="x-ratelimit-remaining"
      retry-after-header-name="Retry-After" />

    <!-- ===================================================================
         Backend Authentication: New Relic API Key injection
         Strip developer's JWT, inject NR API key from named value
         ==================================================================== -->

    <!-- Remove developer's Authorization header -->
    <set-header name="Authorization" exists-action="delete" />

    <!-- Inject New Relic API key from APIM named value (secret) -->
    <set-header name="Api-Key" exists-action="override">
      <value>{{nv-newrelic-mcp-api-key}}</value>
    </set-header>

    <!-- Remove APIM subscription key headers (not needed for NR) -->
    <set-header name="Ocp-Apim-Subscription-Key" exists-action="delete" />
    <set-header name="x-api-key" exists-action="delete" />

    <!-- Route to New Relic MCP backend -->
    <set-backend-service backend-id="{{backend-id-newrelic-mcp}}" />
  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />

    <!-- Add correlation ID to response for traceability -->
    <set-header name="x-correlation-id" exists-action="override">
      <value>@((string)context.Variables["correlationId"])</value>
    </set-header>

    <!-- Track user in response headers for audit -->
    <set-header name="x-apim-mcp-user" exists-action="override">
      <value>@((string)context.Variables["userOid"])</value>
    </set-header>
  </outbound>

  <on-error>
    <base />

    <!-- Preserve correlation ID in error responses -->
    <set-header name="x-correlation-id" exists-action="override">
      <value>@(
        context.Variables.ContainsKey("correlationId")
          ? (string)context.Variables["correlationId"]
          : Guid.NewGuid().ToString()
      )</value>
    </set-header>
  </on-error>
</policies>
